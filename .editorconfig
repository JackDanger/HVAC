# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_style = space
indent_size = 4
# rustfmt enforces these too — editorconfig is the floor when an editor
# doesn't run rustfmt on save.
max_line_length = 100

[*.{yml,yaml,toml,json}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
# Markdown sometimes uses trailing whitespace as a line break; leave it.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sh]
indent_style = space
indent_size = 4
