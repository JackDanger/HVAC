#!/usr/bin/env bash
# Pre-commit hook: refuse the commit if `cargo fmt --check` would change anything.
#
# This hook lives in .githooks/ (committed) instead of .git/hooks/ (untracked) so
# every clone gets the same enforcement. Each contributor wires it up once with:
#
#   git config core.hooksPath .githooks
#
# README's "Development" section repeats this. The hook is silent on success and
# prints the offending diff on failure so you can pipe `cargo fmt --all` and retry.

set -eu

# No cargo / no rustfmt → no enforcement (e.g. a docs-only commit on a machine
# without the Rust toolchain). Skipping is preferable to blocking.
if ! command -v cargo >/dev/null 2>&1; then
    exit 0
fi
if ! cargo fmt --version >/dev/null 2>&1; then
    exit 0
fi

# Only run when at least one .rs file is staged. Pure-docs / config commits
# don't need to wait for rustfmt to start up.
if ! git diff --cached --name-only --diff-filter=ACMR | grep -q '\.rs$'; then
    exit 0
fi

if ! cargo fmt --all -- --check >/dev/null 2>&1; then
    echo "✖ cargo fmt --check failed. Offending diff:" >&2
    cargo fmt --all -- --check >&2 || true
    echo "" >&2
    echo "Fix with:  cargo fmt --all" >&2
    exit 1
fi
